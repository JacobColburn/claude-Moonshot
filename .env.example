# Solana wallet private key (base58 string OR JSON byte array like [1,2,3,...,64])
# Export from Phantom: Settings → Security & Privacy → Show Secret Recovery Phrase
# OR from Solana CLI: cat ~/.config/solana/id.json
SOLANA_PRIVATE_KEY=your_private_key_here

# Optional: custom RPC (public default is rate-limited; Helius/QuickNode free tiers work great)
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Optional: Birdeye API key for richer market data (free tier at birdeye.so)
BIRDEYE_API_KEY=
