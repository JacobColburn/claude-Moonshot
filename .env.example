# ════════════════════════════════════════════════════════════════════════════
#  MOONSHOT ENGINE — configuration
#  Copy to .env and edit. Every value has a sensible default; nothing here is
#  required to run in PAPER mode except (optionally) ANTHROPIC_API_KEY.
# ════════════════════════════════════════════════════════════════════════════

# ── Mode ────────────────────────────────────────────────────────────────────
# false = paper trading (virtual balance, simulated fills) — the safe default.
# true  = LIVE: real swaps through your Solana wallet. Only flip this once the
#         paper equity curve convinces you the strategy works.
LIVE=false

# Starting virtual balance for paper mode (SOL).
PAPER_START_SOL=10

# ── Claude brain (optional but recommended) ─────────────────────────────────
# Without a key the engine runs as a pure quant system. With one, Claude
# Opus 4.8 reviews the top-ranked finalists and assigns a conviction score.
ANTHROPIC_API_KEY=
BRAIN_ENABLED=true
BRAIN_MODEL=claude-opus-4-8

# ── Wallet / network (LIVE mode only) ───────────────────────────────────────
# Base58 string OR JSON byte array. Phantom: Settings → Security → Show key.
SOLANA_PRIVATE_KEY=
# A private RPC (Helius/QuickNode free tier) is strongly recommended for live.
SOLANA_RPC=https://api.mainnet-beta.solana.com

# ── Risk & sizing (tune to taste) ───────────────────────────────────────────
MAX_POSITIONS=6
MAX_POSITION_FRACTION=0.18      # max % of equity on a top-conviction trade
MAX_POSITION_SOL=1.5            # hard per-trade SOL ceiling
MIN_SOL_RESERVE=0.05            # always keep this much unspent
ENTRY_SCORE_THRESHOLD=62        # composite score (0-100) required to buy

# ── Exit management ─────────────────────────────────────────────────────────
HARD_STOP_PCT=-16               # cut losers here
TRAIL_ACTIVATE_PCT=22           # arm the trailing stop once up this much
TRAIL_STOP_PCT=14               # exit when price falls this % from its peak
TIME_STOP_MIN=75                # ditch stale bags after this many minutes

# ── Cadence ─────────────────────────────────────────────────────────────────
SCAN_INTERVAL=20                # seconds between full market scans
POS_REFRESH=8                   # seconds between open-position re-pricing

# ── Dashboard ───────────────────────────────────────────────────────────────
PORT=8000
